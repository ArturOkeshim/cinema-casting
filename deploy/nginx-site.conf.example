# Copy to /etc/nginx/sites-available/ and symlink to sites-enabled.
# Adjust server_name, ssl paths, and upstream port if PORT != 8000.

upstream cinema_casting_app {
    server 127.0.0.1:8000;
    keepalive 8;
}

server {
    listen 80;
    listen [::]:80;
    server_name your-domain.example;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name your-domain.example;

    ssl_certificate     /etc/letsencrypt/live/your-domain.example/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/your-domain.example/privkey.pem;

    client_max_body_size 2M;

    location / {
        proxy_pass http://cinema_casting_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
        # LLM proxy can take up to ~60s
        proxy_read_timeout 120s;
        proxy_send_timeout 120s;
    }
}
